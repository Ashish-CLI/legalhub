{
  "name": "legalhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "wait:db": "wait-on tcp:27017 --timeout 30000",
    "dev": "npm run docker:up && npm run wait:db && next dev",
    "build": "next build",
    "start": "npm run docker:up && npm run wait:db && next start",
    "stop": "npm run docker:down",
    "lint": "eslint",
    "test": "jest --verbose --runInBand",
    "create-admin": "ts-node scripts/create-admin.ts",
    "add-dummy-lawyers": "npx ts-node --project scripts/tsconfig.json scripts/add-dummy-lawyers.ts"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 20000
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.36.0",
    "jose": "^6.2.2",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "mime-types": "^3.0.2",
    "moment": "^2.30.1",
    "mongoose": "^9.2.4",
    "next": "16.1.6",
    "nodemailer": "^8.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "form-data": "^4.0.5",
    "jest": "^30.4.2",
    "node-fetch": "^2.7.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
